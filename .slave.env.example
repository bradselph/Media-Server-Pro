# .slave.env — Slave node configuration for deploy-slave.sh
# Copy this file to .slave.env and fill in your values.
# .slave.env is gitignored — it is safe to put secrets here.

# ── Required for all modes ─────────────────────────────────────────────────────
MASTER_URL=http://your-master-ip:8080
RECEIVER_API_KEY=paste-the-key-from-master-here

# Media directories to share with the master (comma-separated, no spaces)
# Windows example:  MEDIA_DIRS=C:/Videos,D:/Movies
# Linux example:    MEDIA_DIRS=/media/videos,/home/user/music
MEDIA_DIRS=C:/Videos

# ── Identity ───────────────────────────────────────────────────────────────────
SLAVE_ID=my-laptop          # must be unique across all slave nodes
SLAVE_NAME=My Laptop        # display name shown in the admin panel

# ── Timing ────────────────────────────────────────────────────────────────────
LISTEN_ADDR=:9090           # port the slave listens on for media serving
SCAN_INTERVAL=5m            # how often to rescan and push catalog to master
HEARTBEAT_INTERVAL=15s      # keepalive ping interval

# ── Remote deploy only (not needed for --local mode) ──────────────────────────
# SLAVE_HOST=192.168.1.50   # IP or hostname of the slave device
# SLAVE_USER=pi             # SSH user on the slave
# SLAVE_PORT=22             # SSH port
# SLAVE_DIR=/opt/media-receiver
# SLAVE_ARCH=arm64          # leave blank to auto-detect (amd64, arm64, arm)
