# .slave.env — Slave-specific overrides for deploy-slave.sh
# Copy to .slave.env and fill in your values.
# .slave.env is gitignored — safe to put secrets here.
#
# NOTE: MASTER_URL and RECEIVER_API_KEY are written to .deploy.env automatically
# when you run: ./deploy.sh --setup-receiver
# You only need to set them here if you want to override those values.

# ── Identity (required) ────────────────────────────────────────────────────────
SLAVE_ID=my-laptop          # unique ID across all slave nodes
SLAVE_NAME=My Laptop        # display name shown in the admin panel

# ── Media directories (required) ──────────────────────────────────────────────
# Windows paths work fine — use forward slashes or backslashes
MEDIA_DIRS=C:/Videos,D:/Movies

# ── Optional overrides ────────────────────────────────────────────────────────
# MASTER_URL=https://yourdomain.com      # override if auto-detected URL is wrong
# RECEIVER_API_KEY=your-key-here        # override if not using deploy.sh
SCAN_INTERVAL=5m            # how often to rescan and push catalog
HEARTBEAT_INTERVAL=15s      # keepalive ping rate

# ── Remote deploy only (not needed for --local mode) ──────────────────────────
# SLAVE_HOST=192.168.1.50
# SLAVE_USER=pi
# SLAVE_PORT=22
# SLAVE_DIR=/opt/media-receiver
# SLAVE_ARCH=arm64          # leave blank to auto-detect
