# Media Server Pro — Docker Compose environment.
#
# Copy this file to `.env.docker` (kept out of git by .dockerignore) and edit
# the values below. Then bring the stack up with:
#
#   docker compose --env-file .env.docker up -d --build
#
# The server reads these as environment variables; see
# internal/config/env_overrides_*.go for the full override matrix.

# ─── Build args ──────────────────────────────────────────────────────────────
GO_VERSION=1.26
NODE_VERSION=22
# Match these to the host user that owns mounted bind directories, if any.
APP_UID=1000
APP_GID=1000

# ─── Server ─────────────────────────────────────────────────────────────────
SERVER_PORT=8080
# Bind to a specific interface in production (e.g. 127.0.0.1 behind a reverse proxy).
SERVER_BIND=0.0.0.0
LOG_LEVEL=info
TZ=UTC

# ─── Database ───────────────────────────────────────────────────────────────
# REQUIRED — pick strong passwords. The MariaDB container will create the
# database and user on first start; subsequent starts ignore changes here.
DB_ROOT_PASSWORD=change-me-root
DATABASE_NAME=mediaserver
DATABASE_USERNAME=mediaserver
DATABASE_PASSWORD=change-me-app

# ─── Receiver profile (optional) ────────────────────────────────────────────
# Only needed when running with `--profile receiver`.
MASTER_URL=https://master.example.com
RECEIVER_API_KEY=
SLAVE_ID=receiver-1
SLAVE_NAME=Docker Receiver
SCAN_INTERVAL=15m
HEARTBEAT_INTERVAL=30s

# ─── MinIO profile (optional) ───────────────────────────────────────────────
# Only needed when running with `--profile minio`.
# REQUIRED when --profile minio is used. MinIO does not publish semver tags;
# pick the most recent stable RELEASE from https://github.com/minio/minio/releases.
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=mediaserver
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
