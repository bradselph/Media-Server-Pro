# Media Server Pro — Docker Compose environment.
#
# Copy this file to `.env.docker` (kept out of git by .dockerignore) and edit
# the values below. Then bring the stack up with:
#
#   docker compose --env-file .env.docker pull       # default: pull from GHCR
#   docker compose --env-file .env.docker up -d
#
# To build the image from local source instead of pulling, run:
#
#   docker compose --env-file .env.docker build
#   docker compose --env-file .env.docker up -d
#
# The server reads these as environment variables; see
# internal/config/env_overrides_*.go for the full override matrix.

# ─── Image source (pulled from GHCR by default) ─────────────────────────────
# Override IMAGE_OWNER for a fork; pin IMAGE_TAG to a release (e.g. 1.10.32)
# to stop tracking :latest. IMAGE_TAG=edge tracks main between releases.
IMAGE_REGISTRY=ghcr.io
IMAGE_OWNER=bradselph
IMAGE_TAG=latest

# ─── Build args (only used when building locally) ───────────────────────────
GO_VERSION=1.26
NODE_VERSION=22
# Match these to the host user that owns mounted bind directories, if any.
APP_UID=1000
APP_GID=1000

# ─── Server ─────────────────────────────────────────────────────────────────
SERVER_PORT=8080
# Bind to a specific interface in production (e.g. 127.0.0.1 behind a reverse proxy).
SERVER_BIND=0.0.0.0
LOG_LEVEL=info
TZ=UTC

# ─── Database ───────────────────────────────────────────────────────────────
# REQUIRED — pick strong passwords. The MariaDB container will create the
# database and user on first start; subsequent starts ignore changes here.
DB_ROOT_PASSWORD=change-me-root
DATABASE_NAME=mediaserver
DATABASE_USERNAME=mediaserver
DATABASE_PASSWORD=change-me-app

# ─── Admin login (web UI) ───────────────────────────────────────────────────
# Plaintext password works; for production prefer a bcrypt hash via
# ADMIN_PASSWORD_HASH. The server logs a warning and refuses admin login
# when both are blank.
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
# ADMIN_PASSWORD_HASH=$2b$10$...

# ─── Auth / public exposure ────────────────────────────────────────────────
AUTH_SESSION_TIMEOUT_HOURS=24
AUTH_ALLOW_GUESTS=false
# Closed by default — flip to `true` only if you intend an open community.
AUTH_ALLOW_REGISTRATION=false
AUTH_DEFAULT_USER_TYPE=standard
# Set to `true` when serving over HTTPS (Caddy/reverse proxy or direct TLS).
AUTH_SECURE_COOKIES=false

# ─── HTTP security headers ─────────────────────────────────────────────────
CSP_ENABLED=true
# Only enable HSTS once HTTPS is live and you intend to keep it. Browsers
# remember the policy for HSTS_MAX_AGE seconds.
HSTS_ENABLED=false
HSTS_MAX_AGE=15552000

# ─── Streaming / uploads ───────────────────────────────────────────────────
DOWNLOAD_ENABLED=true
UPLOADS_ENABLED=true
UPLOADS_MAX_FILE_SIZE=10737418240

# ─── HLS (defensive: validation requires playlist_length >= 1) ─────────────
HLS_PLAYLIST_LENGTH=6
HLS_SEGMENT_DURATION=6

# ─── Rate limit / CORS ─────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
CORS_ENABLED=true
# Tighten this to your real public origin (e.g. https://example.com) for
# production. `*` is fine for an isolated install reachable only from LAN.
CORS_ORIGINS=*

# ─── Hugging Face (optional — visual mature-content classification) ────────
# Get a key at https://huggingface.co/settings/tokens (read scope is enough).
# Leave HUGGINGFACE_API_KEY blank to disable.
FEATURE_HUGGINGFACE=false
# HUGGINGFACE_API_KEY=
# HUGGINGFACE_MODEL=
# HUGGINGFACE_ENDPOINT_URL=

# ─── Claude assistant module (optional — admin-only) ───────────────────────
# Get a key at https://console.anthropic.com/settings/keys.
# Both ANTHROPIC_API_KEY and CLAUDE_API_KEY are honoured; setting both is
# safe. Mode = advisory | interactive | autonomous (start with advisory).
FEATURE_CLAUDE=false
# ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODE=advisory

# ─── Receiver profile (optional) ────────────────────────────────────────────
# Only needed when running with `--profile receiver`.
MASTER_URL=https://master.example.com
RECEIVER_API_KEY=
SLAVE_ID=receiver-1
SLAVE_NAME=Docker Receiver
SCAN_INTERVAL=15m
HEARTBEAT_INTERVAL=30s

# ─── MinIO profile (optional) ───────────────────────────────────────────────
# Only needed when running with `--profile minio`.
# REQUIRED when --profile minio is used. MinIO does not publish semver tags;
# pick the most recent stable RELEASE from https://github.com/minio/minio/releases.
MINIO_IMAGE_TAG=RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=mediaserver
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
