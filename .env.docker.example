# Media Server Pro — Docker stack environment.
#
# Copy this to .env.docker and edit. Compose loads it via --env-file in
# the documented command (`docker compose --env-file .env.docker up -d`).
#
# This file is the Docker equivalent of the runtime .env that deploy.sh
# writes on a VPS. It mirrors the "runtime" + "build" scopes from
# deploy-knobs.sh PLUS the extra values deploy.sh's `--fix-env` auto-seeds
# on a native install (RECEIVER_API_KEYS, DOWNLOADER_INTERNAL_TOKEN,
# REMOTE_MEDIA_*, HUGGINGFACE_* tuning, …). VPS-only knobs (VPS_HOST,
# KEY_FILE, REPO_URL, HIDRIVE_*, …) are intentionally omitted — they only
# matter when deploy.sh is provisioning a remote host.
#
# docker-compose.yml forwards EVERY line here into the server container via
# `env_file:` — so anything documented below "just works" once uncommented,
# except the build-time knobs (NUXT_PUBLIC_*, GO_VERSION, …) which are baked
# into the image and require `docker compose build` + `up -d` to change.
#
# Any knob left blank falls through to the default baked into the Dockerfile
# or the Go binary. Empty != deleted — the line stays so the next reviewer
# knows the knob exists.
#
# SECURITY: .env.docker holds real secrets (DB passwords, admin password,
# API keys). It is gitignored — never commit it. Single-quote any value
# containing #, $, spaces, or other shell metacharacters.

# ═══════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════
# MariaDB root password — only used by the db container on first boot to
# create the application user. Pick something long; not exposed anywhere
# in the running app. Compose REFUSES TO START with this unset.
DB_ROOT_PASSWORD=

# Application database credentials. The db container creates the database
# and user on first boot using these values; the server then connects with
# DATABASE_USERNAME / DATABASE_PASSWORD via the `db` service name (set in
# docker-compose.yml -- overriding whatever you put for DATABASE_HOST here).
DATABASE_NAME=mediaserver
DATABASE_USERNAME=mediaserver
DATABASE_PASSWORD=

# TLS mode for the MySQL connection (false | true | skip-verify | preferred).
# Inside the compose network the DB is on a private bridge and TLS adds
# CPU without security gain, so default is false. Flip to skip-verify if
# you're pointing at an external DB with a self-signed cert.
DATABASE_TLS_MODE=false

# Master switch for the database layer. The binary REFUSES TO START when
# this is false ("database must be enabled: set DATABASE_ENABLED=true").
# docker-compose.yml hardcodes it to true; it is listed here only so a
# standalone `docker run --env-file .env.docker` (no compose) still works.
DATABASE_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════════════
# Port the server listens on INSIDE the container. The compose file maps
# this to the same port on the host (bound to 127.0.0.1 by default; see
# SERVER_HOST_BIND below to expose externally).
SERVER_PORT=3000

# Host-side bind interface for the port mapping. Defaults to 127.0.0.1
# so the server isn't reachable from the LAN until you opt in.
# - 127.0.0.1 = local only (put Caddy/nginx in front for public access)
# - 0.0.0.0   = reachable on every host interface
# NOTE: irrelevant under Cosmos/Traefik/etc. — a reverse proxy reaches the
# container directly on the compose network, so drop the host port mapping.
SERVER_HOST_BIND=127.0.0.1

# Log verbosity. debug | info | warn | error.
LOG_LEVEL=info

# Go runtime heap cap (e.g. 2GiB, 512MiB, 1024MiB). Leave blank to let the
# server auto-tune. IMPORTANT: the auto-tuner reads /proc/meminfo, which
# reports the HOST's total RAM, not this container's cgroup limit. If you
# run the container with `--memory` / a compose `mem_limit` / under
# Kubernetes, SET THIS to ~75% of that limit or the server will target 75%
# of host RAM and get OOM-killed. Bare-metal / no cgroup limit: leave blank.
GOMEMLIMIT=

# ═══════════════════════════════════════════════════════════════════════
# ADMIN LOGIN
# ═══════════════════════════════════════════════════════════════════════
ADMIN_ENABLED=true
ADMIN_USERNAME=admin

# Plaintext admin password. Convenient for first boot; prefer
# ADMIN_PASSWORD_HASH in production (bcrypt hash, generated with
# `htpasswd -nbBC 10 "" "yourpassword" | cut -d: -f2`).
# Leave blank when using ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=

# Bcrypt hash of the admin password. Takes precedence over ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=

# ═══════════════════════════════════════════════════════════════════════
# USER AUTH / PUBLIC EXPOSURE
# ═══════════════════════════════════════════════════════════════════════
AUTH_ENABLED=true
AUTH_ALLOW_GUESTS=true
AUTH_ALLOW_REGISTRATION=false
AUTH_SESSION_TIMEOUT_HOURS=168

# ═══════════════════════════════════════════════════════════════════════
# HTTP SECURITY HEADERS
# ═══════════════════════════════════════════════════════════════════════
CSP_ENABLED=true
# HSTS only meaningful behind HTTPS. Turn on once the cert is permanent --
# browsers REMEMBER the policy, so flipping prematurely can lock users out.
HSTS_ENABLED=false
# CORS is OFF by default to match the binary. Turning it on WITHOUT a valid
# CORS_ORIGINS emits no Access-Control-* headers (the validator drops empty
# and non-http(s) entries) — which looks like "enabled but broken". To use
# CORS: set CORS_ENABLED=true AND CORS_ORIGINS=https://your-domain.com.
CORS_ENABLED=false
# Comma-separated allowed origins — each must be a full http:// or https:// URL
# (e.g. https://example.com). A bare '*' is NOT a valid entry (the validator drops
# it); leave blank and add your real frontend origin(s) here or via the admin UI.
CORS_ORIGINS=

# ═══════════════════════════════════════════════════════════════════════
# RATE LIMIT
# ═══════════════════════════════════════════════════════════════════════
# Blank = fall through to the binary's secure defaults (enabled, 300 requests / 60s).
RATE_LIMIT_ENABLED=
RATE_LIMIT_REQUESTS=
RATE_LIMIT_WINDOW_SECONDS=

# ═══════════════════════════════════════════════════════════════════════
# AGE GATE
# ═══════════════════════════════════════════════════════════════════════
AGE_GATE_ENABLED=true
AGE_GATE_BYPASS_IPS=127.0.0.1

# ═══════════════════════════════════════════════════════════════════════
# STREAMING / UPLOADS
# ═══════════════════════════════════════════════════════════════════════
DOWNLOAD_ENABLED=true
UPLOADS_ENABLED=true
# Per-file upload cap in bytes. 5368709120 = 5 GiB.
UPLOADS_MAX_FILE_SIZE=5368709120

# ═══════════════════════════════════════════════════════════════════════
# STORAGE BACKEND (local disk vs S3-compatible object store)
# ═══════════════════════════════════════════════════════════════════════
# Docker is the natural home for object storage — a container has no durable
# local disk unless you bind-mount one. Default is local (the /data volume).
# Set STORAGE_BACKEND=s3 to store media in MinIO / Backblaze B2 / AWS S3 /
# any S3-compatible endpoint; when you do, ALL S3_* values below are required
# (the binary warns at startup if backend=s3 but credentials are missing).
STORAGE_BACKEND=local
#S3_ENDPOINT=https://s3.us-west-000.backblazeb2.com
#S3_REGION=us-west-000
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_BUCKET=
# path-style URLs (bucket in the path, not the hostname). MinIO usually needs true.
#S3_USE_PATH_STYLE=false

# ═══════════════════════════════════════════════════════════════════════
# FEDERATION — RECEIVER / MASTER (this instance accepts pushes from peers)
# ═══════════════════════════════════════════════════════════════════════
# Remote-media proxy: pull media from a master this node follows.
FEATURE_REMOTE_MEDIA=true
# Fine-grained remote-media tuning (blank = binary defaults). deploy.sh's
# --fix-env seeds these on native installs; documented here for parity.
REMOTE_MEDIA_ENABLED=false
REMOTE_MEDIA_CACHE_ENABLED=true
# Cache budget in MiB (REMOTE_MEDIA_CACHE_SIZE_MB); 1024 = 1 GiB.
REMOTE_MEDIA_CACHE_SIZE_MB=1024

# Receiver mode: accept media pushes / proxied streams from follower (slave)
# nodes. OFF by default. If you enable it you MUST set RECEIVER_API_KEYS or
# the server EXITS ON STARTUP ("receiver is enabled but no API keys are
# configured") and, with restart: unless-stopped, crash-loops.
FEATURE_RECEIVER=false
RECEIVER_ENABLED=false
# Comma-separated API keys that authenticate follower nodes. Required when
# FEATURE_RECEIVER=true; hand the same key to each slave's FOLLOWER_API_KEY.
# Generate with: openssl rand -hex 32
# (deploy.sh --fix-env auto-generates this on native installs.)
RECEIVER_API_KEYS=

# ═══════════════════════════════════════════════════════════════════════
# FEDERATION — FOLLOWER (this instance is a slave pulling from a master)
# ═══════════════════════════════════════════════════════════════════════
# Leave FOLLOWER_ENABLED=false for a standalone or master node. On a slave,
# set FOLLOWER_ENABLED=true, point FOLLOWER_MASTER_URL at the master, and set
# FOLLOWER_API_KEY to one of the master's RECEIVER_API_KEYS entries.
FOLLOWER_ENABLED=false
FOLLOWER_MASTER_URL=
FOLLOWER_API_KEY=
FOLLOWER_SLAVE_ID=
FOLLOWER_SLAVE_NAME=

# ═══════════════════════════════════════════════════════════════════════
# HUGGING FACE (mature-content visual classifier)
# ═══════════════════════════════════════════════════════════════════════
FEATURE_HUGGINGFACE=false
HUGGINGFACE_ENABLED=false
HUGGINGFACE_API_KEY=
# NSFW image-classification model (the default the binary ships). An image-to-text
# model such as Salesforce/blip-image-captioning-large also works.
HUGGINGFACE_MODEL=Falconsai/nsfw_image_detection
# Classifier tuning (blank = binary defaults; --fix-env seeds these natively).
HUGGINGFACE_MAX_FRAMES=3
HUGGINGFACE_RATE_LIMIT=30
HUGGINGFACE_TIMEOUT_SECS=30
HUGGINGFACE_MAX_CONCURRENT=2

# ═══════════════════════════════════════════════════════════════════════
# DOWNLOADER (standalone external service the server proxies to)
# ═══════════════════════════════════════════════════════════════════════
FEATURE_DOWNLOADER=false
DOWNLOADER_ENABLED=false
# Base URL of the downloader service. NOTE: inside the server container
# "localhost" is the CONTAINER's own loopback, not the host. For Docker use:
#   - http://host.docker.internal:4000   (Docker Desktop on Mac/Windows)
#   - http://172.17.0.1:4000             (host bridge IP, typical on Linux)
#   - http://downloader:4000             (add the downloader as a compose
#                                         service and reference it by name)
DOWNLOADER_URL=http://host.docker.internal:4000
# Container path the downloader writes finished files to (bind/named-volume
# shared with the downloader). Empty = file import disabled.
DOWNLOADER_DOWNLOADS_DIR=
# When set, completed downloads are imported into the library from this path.
DOWNLOADER_IMPORT_DIR=
# Shared secret authenticating the server's admin proxy calls to the
# downloader. Required when FEATURE_DOWNLOADER=true; set the SAME value on
# the downloader as MSP_INTERNAL_TOKEN. Generate with: openssl rand -hex 32
# (deploy.sh --fix-env auto-generates this on native installs.)
DOWNLOADER_INTERNAL_TOKEN=

# ═══════════════════════════════════════════════════════════════════════
# IMAGE TAG (which published image to pull when not building locally)
# ═══════════════════════════════════════════════════════════════════════
# The published GHCR image is PUBLIC. Tag scheme (see .github/workflows/
# docker-publish.yml): "latest" = current stable (there is NO "main" or
# "development" tag), or pin a released version like "1.25.0" for
# reproducible deploys. `docker compose build` still overrides with a local
# image when you'd rather build from this checkout.
IMAGE_TAG=latest

# ═══════════════════════════════════════════════════════════════════════
# BUILD-TIME KNOBS (baked into the image -- require `docker compose build`)
# ═══════════════════════════════════════════════════════════════════════
# Toolchain pins. Keep GO_VERSION in lockstep with go.mod's `go` directive
# (currently 1.26.4); Node major must ship the npm major that writes
# web/nuxt-ui/package-lock.json (npm 11 -> Node 24).
GO_VERSION=1.26.4
NODE_VERSION=24

# User id the runtime user inside the container runs as. Match your host
# uid (`id -u`) when bind-mounting host dirs so file permissions stay sane.
APP_UID=1000
APP_GID=1000

# Frontend knobs surfaced via runtimeConfig.public.<camelCase>.
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_BUILD_ID=
NUXT_PUBLIC_API_BASE=

# Brand
NUXT_PUBLIC_BRAND_NAME=
NUXT_PUBLIC_BRAND_TAGLINE=
NUXT_PUBLIC_BRAND_GRADIENT=

# Adult-site legal compliance (required for public adult sites with US users).
NUXT_PUBLIC_COMPLIANCE_EMAIL=
NUXT_PUBLIC_COMPLIANCE_ADDRESS=
NUXT_PUBLIC_DMCA_AGENT_NAME=
NUXT_PUBLIC_DMCA_EMAIL=
NUXT_PUBLIC_DMCA_ADDRESS=

# ═══════════════════════════════════════════════════════════════════════
# NOT APPLICABLE IN DOCKER (documented so you don't cargo-cult them)
# ═══════════════════════════════════════════════════════════════════════
# - UPDATER_* : the in-app source updater is meaningless when the image IS
#   the deployment artifact. Pin/upgrade via IMAGE_TAG + `docker compose pull`.
# - HIDRIVE_* : the WebDAV cold-tier mount is a VPS/rclone feature. In Docker,
#   bind-mount an rclone FUSE mount from the host into /data/videos instead.
# - CHROME_PATH : the crawler's headless-browser mode (CRAWLER_BROWSER_ENABLED)
#   needs a Chromium binary the slim runtime image does NOT ship. Add a layer
#   with chromium and set CHROME_PATH=/usr/bin/chromium before enabling it.
