# Media Server Pro — Docker stack environment.
#
# Copy this to .env.docker and edit. Compose loads it via --env-file in
# the documented command (`docker compose --env-file .env.docker up -d`).
#
# Only the *runtime* knobs that the Go binary actually reads live here.
# Build-time knobs (NUXT_PUBLIC_*) are also accepted because docker-compose.yml
# forwards them as build args -- changing one of those requires a rebuild
# (`docker compose build` then `up -d`).
#
# The list mirrors the "runtime" + "build" scopes from deploy-knobs.sh,
# minus VPS-specific bits (VPS_HOST, KEY_FILE, REPO_URL, …) which only
# matter when deploy.sh is provisioning a remote host.
#
# Any knob left blank falls through to the default baked into the
# Dockerfile or the Go binary. Empty != deleted -- the line is still
# there so the next reviewer knows the knob exists.

# ═══════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════
# MariaDB root password — only used by the db container on first boot to
# create the application user. Pick something long; not exposed anywhere
# in the running app. Compose REFUSES TO START with this unset.
DB_ROOT_PASSWORD=

# Application database credentials. The db container creates the database
# and user on first boot using these values; the server then connects with
# DATABASE_USERNAME / DATABASE_PASSWORD via the `db` service name (set in
# docker-compose.yml -- overriding whatever you put for DATABASE_HOST here).
DATABASE_NAME=mediaserver
DATABASE_USERNAME=mediaserver
DATABASE_PASSWORD=

# TLS mode for the MySQL connection (false | true | skip-verify | preferred).
# Inside the compose network the DB is on a private bridge and TLS adds
# CPU without security gain, so default is false. Flip to skip-verify if
# you're pointing at an external DB with a self-signed cert.
DATABASE_TLS_MODE=false

# ═══════════════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════════════
# Port the server listens on INSIDE the container. The compose file maps
# this to the same port on the host (bound to 127.0.0.1 by default; see
# SERVER_HOST_BIND below to expose externally).
SERVER_PORT=3000

# Host-side bind interface for the port mapping. Defaults to 127.0.0.1
# so the server isn't reachable from the LAN until you opt in.
# - 127.0.0.1 = local only (put Caddy/nginx in front for public access)
# - 0.0.0.0   = reachable on every host interface
SERVER_HOST_BIND=127.0.0.1

# Log verbosity. debug | info | warn | error.
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════════
# ADMIN LOGIN
# ═══════════════════════════════════════════════════════════════════════
ADMIN_ENABLED=true
ADMIN_USERNAME=admin

# Plaintext admin password. Convenient for first boot; prefer
# ADMIN_PASSWORD_HASH in production (bcrypt hash, generated with
# `htpasswd -nbBC 10 "" "yourpassword" | cut -d: -f2`).
# Leave blank when using ADMIN_PASSWORD_HASH.
ADMIN_PASSWORD=

# Bcrypt hash of the admin password. Takes precedence over ADMIN_PASSWORD.
ADMIN_PASSWORD_HASH=

# ═══════════════════════════════════════════════════════════════════════
# USER AUTH / PUBLIC EXPOSURE
# ═══════════════════════════════════════════════════════════════════════
AUTH_ENABLED=true
AUTH_ALLOW_GUESTS=true
AUTH_ALLOW_REGISTRATION=false
AUTH_SESSION_TIMEOUT_HOURS=168

# ═══════════════════════════════════════════════════════════════════════
# HTTP SECURITY HEADERS
# ═══════════════════════════════════════════════════════════════════════
CSP_ENABLED=true
# HSTS only meaningful behind HTTPS. Turn on once the cert is permanent --
# browsers REMEMBER the policy, so flipping prematurely can lock users out.
HSTS_ENABLED=false
CORS_ENABLED=true
# Comma-separated allowed origins. '*' is permissive; pin to your public
# frontend domain(s) in production.
CORS_ORIGINS=*

# ═══════════════════════════════════════════════════════════════════════
# RATE LIMIT
# ═══════════════════════════════════════════════════════════════════════
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ═══════════════════════════════════════════════════════════════════════
# AGE GATE
# ═══════════════════════════════════════════════════════════════════════
AGE_GATE_ENABLED=true
AGE_GATE_BYPASS_IPS=127.0.0.1

# ═══════════════════════════════════════════════════════════════════════
# STREAMING / UPLOADS
# ═══════════════════════════════════════════════════════════════════════
DOWNLOAD_ENABLED=true
UPLOADS_ENABLED=true
# Per-file upload cap in bytes. 5368709120 = 5 GiB.
UPLOADS_MAX_FILE_SIZE=5368709120

# ═══════════════════════════════════════════════════════════════════════
# FEDERATION (master/slave between Media Server Pro instances)
# ═══════════════════════════════════════════════════════════════════════
FEATURE_REMOTE_MEDIA=true
FEATURE_RECEIVER=true
RECEIVER_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════
# HUGGING FACE (mature-content visual classifier)
# ═══════════════════════════════════════════════════════════════════════
FEATURE_HUGGINGFACE=false
HUGGINGFACE_ENABLED=false
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Salesforce/blip-image-captioning-large

# ═══════════════════════════════════════════════════════════════════════
# DOWNLOADER (standalone external service the server proxies to)
# ═══════════════════════════════════════════════════════════════════════
FEATURE_DOWNLOADER=false
DOWNLOADER_ENABLED=false
DOWNLOADER_URL=http://localhost:4000
DOWNLOADER_DOWNLOADS_DIR=

# ═══════════════════════════════════════════════════════════════════════
# CLAUDE ASSISTANT (admin-only)
# ═══════════════════════════════════════════════════════════════════════
FEATURE_CLAUDE=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# advisory | interactive | autonomous
CLAUDE_MODE=autonomous

# ═══════════════════════════════════════════════════════════════════════
# IMAGE TAG (which published image to pull when not building locally)
# ═══════════════════════════════════════════════════════════════════════
# Set to "main" for the latest stable, "development" for the dev branch,
# or pin to a specific version like "1.14.16" for reproducible deploys.
IMAGE_TAG=main

# ═══════════════════════════════════════════════════════════════════════
# BUILD-TIME KNOBS (baked into the Nuxt bundle -- require rebuild on change)
# ═══════════════════════════════════════════════════════════════════════
# Toolchain pins. Empty = whatever the Dockerfile specifies (Go 1.26, Node 22).
GO_VERSION=1.26
NODE_VERSION=22

# User id the runtime user inside the container runs as. Match your host
# uid (`id -u`) when bind-mounting host dirs so file permissions stay sane.
APP_UID=1000
APP_GID=1000

# Frontend knobs surfaced via runtimeConfig.public.<camelCase>.
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_BUILD_ID=
NUXT_PUBLIC_API_BASE=

# Brand
NUXT_PUBLIC_BRAND_NAME=
NUXT_PUBLIC_BRAND_TAGLINE=
NUXT_PUBLIC_BRAND_GRADIENT=

# Adult-site legal compliance (required for public adult sites with US users).
NUXT_PUBLIC_COMPLIANCE_EMAIL=
NUXT_PUBLIC_COMPLIANCE_ADDRESS=
NUXT_PUBLIC_DMCA_AGENT_NAME=
NUXT_PUBLIC_DMCA_EMAIL=
NUXT_PUBLIC_DMCA_ADDRESS=
