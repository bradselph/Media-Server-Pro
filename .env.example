# ═══════════════════════════════════════════════════════════════
#  Media Server Pro — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  .env is loaded automatically on startup (joho/godotenv).
#  All values here override config.json settings.
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=60s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=30s
SERVER_MAX_HEADER_BYTES=1048576

# HTTPS (leave blank to use HTTP)
SERVER_ENABLE_HTTPS=false
SERVER_CERT_FILE=
SERVER_KEY_FILE=

# ── Directories ───────────────────────────────────────────────
VIDEOS_DIR=./videos
MUSIC_DIR=./music
THUMBNAILS_DIR=./thumbnails
UPLOADS_DIR=./uploads
CACHE_DIR=./cache
LOGS_DIR=./logs
DATA_DIR=./data
HLS_CACHE_DIR=./cache/hls
BACKUP_DIR=./backups

# ── Database (MySQL — required) ───────────────────────────────
DATABASE_ENABLED=true
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=mediaserver
DATABASE_USERNAME=mediaserver
DATABASE_PASSWORD=change_me_in_production
DATABASE_TLS_MODE=
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME=1h
DATABASE_TIMEOUT=10s
DATABASE_MAX_RETRIES=3
DATABASE_RETRY_INTERVAL=2s

# ── Streaming ─────────────────────────────────────────────────
STREAMING_CHUNK_SIZE=1048576
STREAMING_MOBILE_OPTIMIZATION=true
STREAMING_MAX_CONCURRENT=100

# ── HLS ──────────────────────────────────────────────────────
HLS_ENABLED=true
HLS_SEGMENT_DURATION=6
HLS_CONCURRENT_LIMIT=2          # also accepted: HLS_MAX_CONCURRENT_JOBS
HLS_AUTO_GENERATE=false
HLS_QUALITIES=480p,720p,1080p   # comma-separated names from quality_profiles in config.json

# ── Thumbnails ────────────────────────────────────────────────
THUMBNAILS_ENABLED=true
THUMBNAILS_AUTO_GENERATE=true
THUMBNAILS_WIDTH=320
THUMBNAILS_HEIGHT=180
THUMBNAILS_PREVIEW_COUNT=5

# ── Analytics ─────────────────────────────────────────────────
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# ── Uploads ───────────────────────────────────────────────────
UPLOADS_ENABLED=true
UPLOADS_MAX_FILE_SIZE=10737418240
UPLOADS_ALLOWED_EXTENSIONS=mp4,mkv,webm,avi,mov,mp3,flac,wav,aac,ogg

# ── Security ──────────────────────────────────────────────────
SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW=1m
SECURITY_CORS_ENABLED=true
SECURITY_CORS_ORIGINS=*
SECURITY_CSP_ENABLED=false
SECURITY_CSP_POLICY=
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_ENABLE_IP_WHITELIST=false
SECURITY_ENABLE_IP_BLACKLIST=false
SECURITY_IP_WHITELIST=
SECURITY_IP_BLACKLIST=

# ── Authentication ────────────────────────────────────────────
AUTH_SESSION_TIMEOUT=24h
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=15m
AUTH_GUEST_ACCESS=true
AUTH_ALLOW_REGISTRATION=true

# ── Admin ─────────────────────────────────────────────────────
ADMIN_ENABLED=true
ADMIN_USERNAME=admin
# Set one of these — ADMIN_PASSWORD is hashed automatically on startup (convenience)
# ADMIN_PASSWORD_HASH is a pre-computed bcrypt hash (preferred for production)
ADMIN_PASSWORD=change_me_in_production
ADMIN_PASSWORD_HASH=

# ── Age Gate ──────────────────────────────────────────────────
AGE_GATE_ENABLED=false
AGE_GATE_COOKIE_NAME=age_verified
AGE_GATE_COOKIE_MAX_AGE=31536000
AGE_GATE_IP_VERIFY_TTL=24h
AGE_GATE_BYPASS_IPS=127.0.0.1,::1

# ── Mature Content Scanner ────────────────────────────────────
SCANNER_ENABLED=true
SCANNER_AUTO_FLAG_THRESHOLD=0.85
SCANNER_AUTO_APPLY=false
SCANNER_REVIEW_QUEUE_SIZE=500

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=text
LOG_FILE_ENABLED=true
LOG_FILE_MAX_SIZE=104857600
LOG_FILE_MAX_BACKUPS=5

# ── Features ─────────────────────────────────────────────────
FEATURE_HLS=true
FEATURE_ANALYTICS=true
FEATURE_UPLOADS=true
FEATURE_ADMIN=true
FEATURE_SUGGESTIONS=true
FEATURE_REMOTE_MEDIA=false
FEATURE_RECEIVER=false

# ── Updater ───────────────────────────────────────────────────
UPDATER_ENABLED=true
UPDATER_GITHUB_TOKEN=
UPDATER_CHECK_INTERVAL=24h

# ── Remote Media ──────────────────────────────────────────────
REMOTE_MEDIA_ENABLED=false
REMOTE_CACHE_DIR=./cache/remote
REMOTE_CACHE_SIZE_MB=1024
