# deploy.sh configuration — copy to .deploy.env and fill in values.
# .deploy.env is gitignored and never committed.

VPS_HOST=your-vps-ip
VPS_USER=root
VPS_PORT=22
KEY_FILE=~/.ssh/id_ed25519
DEPLOY_DIR=/opt/media-server
SERVICE=media-server

# GitHub Personal Access Token (required for private repos)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Repository URL (without https:// prefix — token is prepended automatically)
REPO_URL=github.com/bradselph/Media-Server-Pro.git
