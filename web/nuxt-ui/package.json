{
  "name": "media-server-pro-nuxt-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt generate",
    "codegen:openapi": "openapi-typescript ../../api_spec/openapi.yaml -o types/openapi.generated.ts",
    "verify:openapi-types": "tsc --noEmit --skipLibCheck types/openapi.generated.ts",
    "check": "npm run codegen:openapi && npm run verify:openapi-types && nuxi typecheck && nuxt generate",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "@nuxt/icon": "^1.12.0",
    "@nuxt/ui": "^3.0.2",
    "@nuxtjs/color-mode": "^3.5.2",
    "@pinia/nuxt": "^0.10.0",
    "hls.js": "^1.5.20",
    "nuxt": "^3.16.1",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@types/node": "^22.13.10",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.8.2"
  }
}
