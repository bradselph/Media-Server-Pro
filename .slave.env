# TODO: MASTER_URL and RECEIVER_API_KEY are required by the media-receiver
# binary and by deploy.sh --slave, but are missing from this file. The slave
# will fail to connect without them. Add:
#   MASTER_URL=https://your-master-server.com
#   RECEIVER_API_KEY=<key from master .env RECEIVER_API_KEYS>
SLAVE_ID=remote
SLAVE_NAME=remote
MEDIA_DIRS=./videos
SCAN_INTERVAL=5m
HEARTBEAT_INTERVAL=15s